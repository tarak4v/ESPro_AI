/**
 * @file secrets.h.example
 * @brief Copy to secrets.h and fill in your API keys.
 *
 * NOTE: API keys and WiFi credentials are now configurable at runtime
 * via the web config portal (http://192.168.4.1). These compile-time
 * defaults are only used if no runtime config has been saved to NVS.
 *
 * You can leave these empty and configure everything via the web portal.
 */
#ifndef SECRETS_H
#define SECRETS_H

/* Optional compile-time defaults (runtime config takes precedence) */
#define WIFI_SSID             ""
#define WIFI_PASS             ""
#define WEATHER_API_KEY       ""
#define GROQ_API_KEY          ""
#define HF_API_TOKEN          ""

#endif /* SECRETS_H */
