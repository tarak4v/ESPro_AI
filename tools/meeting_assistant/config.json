    "keyboard_shortcuts": {
        "meet": {
            "mic": "ctrl+d",
            "video": "ctrl+e",
            "hand": "ctrl+alt+h"
        },
        "teams": {
            "mic": "ctrl+shift+m",
            "video": "ctrl+shift+o",
            "hand": "ctrl+shift+k"
        },
        "zoom": {
            "mic": "alt+a",
            "video": "alt+v",
            "hand": "alt+y"
        }
